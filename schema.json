{
    "$defs": {
        "AdditionalInfo": {
            "additionalProperties": false,
            "properties": {
                "prompt": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "title": "提示文本"
                },
                "required": {
                    "default": false,
                    "title": "是否必填",
                    "type": "boolean"
                }
            },
            "title": "AdditionalInfo",
            "type": "object"
        },
        "AnyQuestion": {
            "anyOf": [
                {
                    "$ref": "#/$defs/RadioQuestion"
                },
                {
                    "$ref": "#/$defs/CheckboxQuestion"
                },
                {
                    "$ref": "#/$defs/FillBlankQuestion"
                },
                {
                    "$ref": "#/$defs/TextAreaQuestion"
                }
            ],
            "discriminator": {
                "propertyName": "type"
            }
        },
        "CheckboxQuestion": {
            "additionalProperties": false,
            "properties": {
                "num": {
                    "title": "题号",
                    "type": "integer"
                },
                "title": {
                    "default": "",
                    "title": "题干",
                    "type": "string"
                },
                "type": {
                    "const": "checkbox",
                    "default": "checkbox",
                    "title": "Type",
                    "type": "string"
                },
                "required": {
                    "default": true,
                    "title": "是否必填",
                    "type": "boolean"
                },
                "prompt": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "title": "填报提示"
                },
                "options": {
                    "items": {
                        "$ref": "#/$defs/Option"
                    },
                    "title": "选项列表",
                    "type": "array"
                }
            },
            "required": [
                "num",
                "options"
            ],
            "title": "CheckboxQuestion",
            "type": "object"
        },
        "FillBlankQuestion": {
            "additionalProperties": false,
            "properties": {
                "num": {
                    "title": "题号",
                    "type": "integer"
                },
                "title": {
                    "default": "",
                    "title": "题干",
                    "type": "string"
                },
                "type": {
                    "const": "fill_blank",
                    "default": "fill_blank",
                    "title": "Type",
                    "type": "string"
                },
                "required": {
                    "default": true,
                    "title": "是否必填",
                    "type": "boolean"
                },
                "prompt": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "title": "填报提示"
                },
                "blank_count": {
                    "default": 2,
                    "description": "fill_blank 类型的多项填空题，空格数必须大于 1",
                    "minimum": 2,
                    "title": "空格数量",
                    "type": "integer"
                },
                "regex": {
                    "anyOf": [
                        {
                            "items": {
                                "type": "string"
                            },
                            "type": "array"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "title": "正则校验规则"
                },
                "default_blank_text": {
                    "anyOf": [
                        {
                            "additionalProperties": {
                                "type": "string"
                            },
                            "type": "object"
                        },
                        {
                            "items": {
                                "type": "string"
                            },
                            "type": "array"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "description": "各空格的默认填充文本。dict 格式：键为空格序号（从1起），值为默认文本；list 格式：按顺序对应每个空格，长度须等于 blank_count。",
                    "title": "默认填充文本"
                }
            },
            "required": [
                "num"
            ],
            "title": "FillBlankQuestion",
            "type": "object"
        },
        "Option": {
            "additionalProperties": false,
            "description": "选项的定义",
            "properties": {
                "text": {
                    "title": "选项文本",
                    "type": "string"
                },
                "additional_text": {
                    "anyOf": [
                        {
                            "$ref": "#/$defs/AdditionalInfo"
                        },
                        {
                            "type": "boolean"
                        }
                    ],
                    "default": false,
                    "title": "附加文本"
                }
            },
            "required": [
                "text"
            ],
            "title": "Option",
            "type": "object"
        },
        "RadioQuestion": {
            "additionalProperties": false,
            "properties": {
                "num": {
                    "title": "题号",
                    "type": "integer"
                },
                "title": {
                    "default": "",
                    "title": "题干",
                    "type": "string"
                },
                "type": {
                    "const": "radio",
                    "default": "radio",
                    "title": "Type",
                    "type": "string"
                },
                "required": {
                    "default": true,
                    "title": "是否必填",
                    "type": "boolean"
                },
                "prompt": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "title": "填报提示"
                },
                "options": {
                    "items": {
                        "$ref": "#/$defs/Option"
                    },
                    "title": "选项列表",
                    "type": "array"
                }
            },
            "required": [
                "num",
                "options"
            ],
            "title": "RadioQuestion",
            "type": "object"
        },
        "TextAreaQuestion": {
            "additionalProperties": false,
            "properties": {
                "num": {
                    "title": "题号",
                    "type": "integer"
                },
                "title": {
                    "default": "",
                    "title": "题干",
                    "type": "string"
                },
                "type": {
                    "const": "text_area",
                    "default": "text_area",
                    "title": "Type",
                    "type": "string"
                },
                "required": {
                    "default": true,
                    "title": "是否必填",
                    "type": "boolean"
                },
                "prompt": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "title": "填报提示"
                },
                "length_limit": {
                    "anyOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "type": "null"
                        }
                    ],
                    "default": null,
                    "title": "字数限制"
                }
            },
            "required": [
                "num"
            ],
            "title": "TextAreaQuestion",
            "type": "object"
        }
    },
    "items": {
        "$ref": "#/$defs/AnyQuestion"
    },
    "type": "array"
}
