{
    "$defs": {
        "AnyQuestion": {
            "discriminator": {
                "mapping": {
                    "checkbox": "#/$defs/CheckboxQuestion",
                    "fill_blank": "#/$defs/FillBlankQuestion",
                    "radio": "#/$defs/RadioQuestion",
                    "text_area": "#/$defs/TextAreaQuestion"
                },
                "propertyName": "type"
            },
            "oneOf": [
                {
                    "$ref": "#/$defs/RadioQuestion"
                },
                {
                    "$ref": "#/$defs/CheckboxQuestion"
                },
                {
                    "$ref": "#/$defs/FillBlankQuestion"
                },
                {
                    "$ref": "#/$defs/TextAreaQuestion"
                }
            ]
        },
        "CheckboxQuestion": {
            "properties": {
                "num": {
                    "title": "Num",
                    "type": "integer"
                },
                "title": {
                    "default": "",
                    "title": "Title",
                    "type": "string"
                },
                "type": {
                    "const": "checkbox",
                    "default": "checkbox",
                    "title": "Type",
                    "type": "string"
                },
                "required": {
                    "default": true,
                    "title": "Required",
                    "type": "boolean"
                },
                "prompt": {
                    "anyOf": [
                        {
                            "type": "string"
                        },
                        {
                            "type": "null"
