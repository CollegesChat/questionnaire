                },
                "options": {
                    "items": {
                        "$ref": "#/$defs/Option"
                    },
                    "title": "Options",
                    "type": "array"
                }
            },
            "required": [
                "num",
                "options"
            ],
            "title": "CheckboxQuestion",
            "type": "object"
        },
        "FillBlankQuestion": {
            "properties": {
                "regex": {
                    "items": {
                        "type": "string"
                    },
